# ============================================================================
# CBC-Provenance Environment Configuration
# ============================================================================

# Ethereum/Arbitrum Configuration
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_CHAIN_ID=421614
ARBITRUM_CONTRACT_ADDRESS=0x145D...  # Your deployed contract address
ARBITRUM_GAS_PRICE=1000000000         # 1 Gwei

# Smart Contract Deployment
HARDHAT_NETWORK=arbitrumSepolia
DEPLOYER_PRIVATE_KEY=0x...            # Your deployer wallet private key
CONTRACT_OWNER_ADDRESS=0x...          # Contract owner address

# IPFS Configuration
IPFS_API_URL=http://localhost:5001    # Local IPFS API
IPFS_GATEWAY_URL=https://ipfs.io      # Public IPFS gateway
IPFS_TIMEOUT=30000                    # 30 seconds

# Issuer Node Configuration (Python)
ISSUER_DID=did:key:z6Mkw...           # Your issuer DID
ISSUER_PRIVATE_KEY=<base64-encoded-key>
ISSUER_SERVICE_URL=http://localhost:8000
ISSUER_API_KEY=your-api-key-here
ISSUER_RATE_LIMIT=100                 # Requests per minute

# VC Issuance Settings
VC_EXPIRATION_DAYS=365
VC_ISSUER_NAME=MyOrganization
VC_ISSUER_EMAIL=issuer@example.com

# Kubernetes Admission Webhook Configuration
WEBHOOK_PORT=8443
WEBHOOK_TLS_CERT_PATH=/etc/webhook/certs/tls.crt
WEBHOOK_TLS_KEY_PATH=/etc/webhook/certs/tls.key
WEBHOOK_ENABLE_CACHE=true
WEBHOOK_CACHE_TTL=3600                # 1 hour
WEBHOOK_FAIL_CLOSED=true              # Fail-closed on errors
WEBHOOK_LOG_LEVEL=info

# Expected CBC Context (for verifier)
VERIFIER_CHAIN_ID=421614
VERIFIER_CONTRACT_ADDRESS=0x145D...

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Development/Testing
ENVIRONMENT=production                # or 'development', 'testing'
DEBUG=false
